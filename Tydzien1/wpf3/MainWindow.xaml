<Window x:Class="Inf04Tydzien1Zad7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien1Zad7"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.9*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Rodzaj przesyłki" Grid.Column="0" Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <RadioButton Content="List [5 zł]" GroupName="przesylka" x:Name="listRdBtn" FontSize="20"  VerticalContentAlignment="Center" Margin="20" Click="listRdBtn_Click"/>
                <RadioButton Content="Paczka [15 zł]" GroupName="przesylka" x:Name="paczkaRdBtn" FontSize="20"  VerticalContentAlignment="Center" Margin="20" Click="paczkaRdBtn_Click"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Opcje dodatkowe" Grid.Column="0" Grid.Row="1">
            <StackPanel VerticalAlignment="Center">
                <CheckBox x:Name="ubezpieczenieCK" Content="Ubezpiecznie [+3 zł]" VerticalContentAlignment="Center" FontSize="20" Margin="20"/>
                <CheckBox x:Name="priorytetCK" Content="Priorytet [+10 zł]" VerticalContentAlignment="Center" FontSize="20" Margin="20"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Background="AliceBlue" Margin="5 0 0 0">
            <Label Content="PODSUMOWANIE" Foreground="DeepSkyBlue" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="podsumowanieTxtBlock" Margin="5 0" FontSize="16" Height="220" HorizontalAlignment="Center"/>
            <Label x:Name="etykietaLbl" Content="" FontSize="12" Margin="5 5 5 0 " HorizontalAlignment="Center"/>
            <Button IsEnabled="False" x:Name="obliczBtn" Content="Oblicz Koszt" FontSize="30" Padding="10" Width="200" Background="DeepSkyBlue" Foreground="White" FontWeight="Bold" Margin="0 15 0 0" Click="obliczBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
