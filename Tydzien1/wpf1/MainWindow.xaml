<Window x:Class="Inf04Tydzien1Zad5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien1Zad5"
        mc:Ignorable="d"
        Title="Rejestr egzaminatorów" Height="460" Width="440"
        Background="CadetBlue">
    <StackPanel>
        <GroupBox Header="Sekcja Wyszukiwania">
            <StackPanel Orientation="Vertical" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="idTxtBox" Width="200" Height="20" Margin="0 0 20 0" TextChanged="idTxtBox_TextChanged" />
                    <Button x:Name="szukajBtn" Width="80" Height="20" Content="Wyszukaj" Click="szukajBtn_Click"/>
                </StackPanel>
                <Label x:Name="wynikWyszukiwaniaLbl" Content="" Foreground="DarkGreen"/>
            </StackPanel>    
        </GroupBox>
        <GroupBox Header="Sekcja Dodawania" Margin="0 5 0 0">
            <StackPanel Margin="5" HorizontalAlignment="Center">
                <Label Content="Imie:"/>
                <TextBox x:Name="imieTxtBox" Width="300" Height="20" Margin="0 0 0 5"/>
                <Label Content="Nazwisko:"/>
                <TextBox x:Name="nazwiskoTxtBox" Width="300" Height="20" Margin="0 0 0 5"/>
                <Label Content="Specjalizacja:"/>
                <ComboBox Width="300" Height="20" x:Name="specjalizacjaCmbBox">
                    <ComboBoxItem Content="INF.02"/>
                    <ComboBoxItem Content="INF.03"/>
                    <ComboBoxItem Content="INF.04"/>
                </ComboBox>
                <Button x:Name="dodajBtn" Content="Dodaj Egzaminatora" Margin="0 10" Width="200" Height="20" Click="dodajBtn_Click"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Lista egzaminatorów" Margin="0 5 0 0" Height="130">
            <ListBox x:Name="egzaminatorzyListBox" Height="80"/>
        </GroupBox>
    </StackPanel>
</Window>
