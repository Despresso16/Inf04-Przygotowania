<Window x:Class="Inf04Tydzien1Zad6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien1Zad6"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <ListView x:Name="listaProduktowListView" Grid.Column="0" Grid.Row="0" SelectionChanged="listaProduktowListView_SelectionChanged" />
        <StackPanel Grid.Column="1" Grid.Row="0" Margin="10 0 0 0">
            <TextBlock x:Name="pelnaNazwaTxtBlock" Text="" FontSize="60"/>
            <Label x:Name="statusKoduLbl" Content="" Foreground="Green" FontSize="30"/>
            <Label x:Name="etykietaLbl" Content="" FontSize="30" FontFamily="Monospace"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Background="SkyBlue">
            <Label x:Name="statusSystemuLbl" Content="" FontSize="20" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
