<Window x:Class="Inf04Tydzien2Zad14.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien2Zad14"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <ListView x:Name="sprzetListView" Grid.Column="0" Grid.Row="0" SelectionChanged="sprzetListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nr." DisplayMemberBinding="{Binding NumerInwentarzowy}" Width="30"/>
                    <GridViewColumn Header="Nazwa" DisplayMemberBinding="{Binding Nazwa}" Width="150"/>
                    <GridViewColumn Header="Typ" DisplayMemberBinding="{Binding TypFormat}" Width="65"/>
                    <GridViewColumn Header="Rok" DisplayMemberBinding="{Binding RokZakupu}" Width="50"/>
                    <GridViewColumn Header="Wartość" DisplayMemberBinding="{Binding WartoscFormat}" Width="65"/>
                    <GridViewColumn Header="Sala" DisplayMemberBinding="{Binding PrzypisanaSala}" Width="115"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Grid.Row="0">
            <Label x:Name="nazwaLbl" Content="" FontSize="25" Margin="10" HorizontalContentAlignment="Center" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label x:Name="numerLbl" Content="" FontSize="15" Margin="10"/>
                <Label x:Name="typLbl" Content="" FontSize="15" Margin="10"/>
                <Label x:Name="rokLbl" Content="" FontSize="15" Margin="10"/>
            </StackPanel>
            <Label x:Name="wartoscLbl" Content="" FontSize="20" Margin="10" HorizontalContentAlignment="Center"/>
            <Label x:Name="statusLbl" Content="" FontSize="20" Margin="10" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Label x:Name="iloscLbl" Content="..." FontSize="15" Margin="20 0" HorizontalContentAlignment="Center"/>
            <Label x:Name="lacznyKosztLbl" Content="..." FontSize="15" Margin="20 0" HorizontalContentAlignment="Center"/>
            <Button x:Name="eksportBtn" Content="Eksportuj" FontSize="15" Margin="50 0 10 0" Click="eksportBtn_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
