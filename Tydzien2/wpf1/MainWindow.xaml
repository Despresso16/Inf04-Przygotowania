<Window x:Class="Inf04Tydzien2Zad10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien2Zad10"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.6*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Wybierz rodzaj przesyłki" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="10">
            <StackPanel Margin="5" VerticalAlignment="Center">
                <RadioButton x:Name="listRdBtn" Content="List" FontSize="22" VerticalContentAlignment="Center" Margin="0 20" Checked="listRdBtn_Checked"/>
                <RadioButton x:Name="paczkaRdBtn" Content="Paczka" FontSize="22" VerticalContentAlignment="Center" Margin="0 20" Checked="paczkaRdBtn_Checked"/>
                <RadioButton x:Name="kurierRdBtn" Content="Kurier ekspresowy" FontSize="22" VerticalContentAlignment="Center" Margin="0 20" Checked="kurierRdBtn_Checked"/>
            </StackPanel>
        </GroupBox>

        <Image Grid.Column="1" Grid.Row="0" Source="/images/list.png" Margin="5" Stretch="Uniform" x:Name="obrazekImg"/>

        <StackPanel Grid.Column="1" Grid.Row="1">
            <TextBlock x:Name="cenaTxtBlock" Text="Cena: 4,99 zł" FontSize="25" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock x:Name="opisTxtBlock" Text="Czas dostawy 21-37 dni roboczych" FontSize="25" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
