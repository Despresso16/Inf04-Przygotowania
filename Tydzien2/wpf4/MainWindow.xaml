<Window x:Class="Inf04Tydzien2Zad13.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien2Zad13"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <ListView Grid.Column="0" x:Name="gryListView" SelectionChanged="gryListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Header="Tytul"
                        DisplayMemberBinding="{Binding tytul}"
                        Width="150"/>
                    <GridViewColumn
                        Header="Gatunek"
                        DisplayMemberBinding="{Binding gatunek}"
                        Width="100"/>
                    <GridViewColumn
                        Header="Rok"
                        DisplayMemberBinding="{Binding rokWydania}"
                        Width="50"/>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Column="1" Margin="10 0 5 0">
            <Label Content="" FontSize="40" x:Name="tytulLbl" FontWeight="Bold"/>
            <Image Source="/Images/default.png" Margin="5" Width="125" Height="125" x:Name="obrazekImg" Visibility="Hidden"/>
            <StackPanel Orientation="Horizontal" Margin="40 5 " HorizontalAlignment="Center">
                <Label x:Name="gatunekLbl"  Content="" FontSize="20" Margin="10 0"/>
                <Label x:Name="rokLbl"  Content="" FontSize="20" Margin="10 0"/>
            </StackPanel>
            <Label x:Name="ocenaLbl"  Content="" FontSize="20" Margin="10 0" HorizontalContentAlignment="Center"/>

            <TextBlock x:Name="opisTxtBlock" Text="" Margin="10 0" TextAlignment="Center" Width="300" Height="70" FontSize="20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="prevBtn" Margin="5" Content="PREV" FontSize="20" Click="prevBtn_Click" IsEnabled="False"/>
                <Button x:Name="nextBtn" Margin="5" Content="NEXT" FontSize="20" Click="nextBtn_Click" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
