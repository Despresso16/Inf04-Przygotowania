<Window x:Class="Inf04Tydzien2Zad11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien2Zad11"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="zadaniaListBox" Grid.Column="0" Margin="5 0" SelectionChanged="zadaniaListBox_SelectionChanged">
            
        </ListBox>

        <StackPanel Grid.Column="1" Margin="5" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <Label Content="Opis:" FontSize="20" Margin="0 0 10 0"/>
                <TextBox x:Name="opisTxtBox" FontSize="20" Width="300" TextChanged="opisTxtBox_TextChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <Label Content="Priorytet:" FontSize="20" Margin="0 0 10 0"/>
                <ComboBox Width="265" FontSize="20" x:Name="priorytetCmbBox">
                    <ComboBoxItem Content="Bardzo ważne"/>
                    <ComboBoxItem Content="Ważne"/>
                    <ComboBoxItem Content="Mało ważne"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <Label Content="Termin:" FontSize="20" Margin="0 0 10 0"/>
                <DatePicker x:Name="terminDatePicker" Width="280" VerticalContentAlignment="Center" Padding="10 0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <Label Content="Status:" FontSize="20" Margin="0 0 10 0"/>
                <ComboBox Width="285" FontSize="20" x:Name="statusCmbBox">
                    <ComboBoxItem Content="Nowe" IsSelected="True"/>
                    <ComboBoxItem Content="W trakcie"/>
                    <ComboBoxItem Content="Zakończone"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 40 0 0" HorizontalAlignment="Center">
                <Button x:Name="dodajBtn" Content="Dodaj zadanie" FontSize="20" Padding="5" IsEnabled="False" Margin="10" Click="dodajBtn_Click"/>
                <Button x:Name="usunBtn" Content="Usun zadanie" FontSize="20" Padding="5" IsEnabled="False" Margin="10" Click="usunBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
