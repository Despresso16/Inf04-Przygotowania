<Window x:Class="Inf04Tydzien2Zad12._1.OknoDialogowe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien2Zad12._1"
        mc:Ignorable="d"
        Title="OknoDialogowe" Height="450" Width="400">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <Label Content="Nowy pracownik" FontSize="40" HorizontalContentAlignment="Center"/>
        <Label Content="Imie:"/>
        <TextBox x:Name="imieTxtBox" Width="200" TextChanged="imieTxtBox_TextChanged"/>
        <Label Content="Nazwisko:"/>
        <TextBox x:Name="nazwiskoTxtBox" Width="200" TextChanged="nazwiskoTxtBox_TextChanged"/>
        <Label Content="Rodzaj:"/>
        <ComboBox x:Name="typCmbBox" Width="200">
            <ComboBoxItem Content="Etatowy" IsSelected="True"/>
            <ComboBoxItem Content="Godzinowy"/>
        </ComboBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="okBtn" Content="OK" Margin="20" IsEnabled="False" Click="okBtn_Click"/>
            <Button x:Name="anulujBtn" Content="Anuluj" Margin="20" Click="anulujBtn_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
