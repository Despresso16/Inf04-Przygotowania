<Window x:Class="Inf04Tydzien2Zad12._1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inf04Tydzien2Zad12._1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <ListBox Grid.Column="0" Background="LightGray" x:Name="pracownicyListBox"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1">
            <Label x:Name="licznikLbl" Content="..." FontSize="50" Margin="20"/>
            <Button x:Name="dodajBtn" Content="Dodaj" Margin="10" FontSize="25" Click="dodajBtn_Click"/>
            <Button x:Name="usunBtn" Content="Usun" Margin="10" FontSize="25" IsEnabled="False"/>

        </StackPanel>
    </Grid>
</Window>
